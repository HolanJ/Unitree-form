{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "strict": false,
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": ["src", "vite.config.js", "tailwind.config.js"]
}
